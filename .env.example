# ==============================
# TaskAgent — Environment Variables
# ==============================
# Copy this file to .env and fill in your keys.
# Docker Compose reads this automatically.
# For local dev (npm run dev), the backend also reads backend/.env via dotenv.

# --- Required ---
GROQ_API_KEY=gsk_your_key_here

# --- Optional ---
GROQ_MODEL=llama-3.3-70b-versatile

# --- Infra (defaults work for Docker Compose, change for local dev) ---
DATABASE_URL=postgresql://taskagent:taskagent@postgres:5432/taskagent
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
